# --- FleetBox configuration -------------------------------------------------
# Copy this file to ".env" and adjust the values. See docs/configuration.md.

# REQUIRED: secret used to sign session cookies. Generate a random one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FLEETBOX_SECRET_KEY=change-me-please-generate-a-random-value

# Database URL (SQLAlchemy syntax).
# SQLite (default):
FLEETBOX_DATABASE_URL=sqlite:///./data/fleetbox.db
# PostgreSQL example:
# FLEETBOX_DATABASE_URL=postgresql+psycopg://fleetbox:secret@localhost:5432/fleetbox

# Network
FLEETBOX_HOST=0.0.0.0
FLEETBOX_PORT=8000

# Default UI language: "de" or "en"
FLEETBOX_DEFAULT_LOCALE=de

# Allow self-service registration of new users (true/false).
# When false, only an admin can create users.
FLEETBOX_ALLOW_REGISTRATION=true

# Session lifetime in seconds (default: 14 days)
FLEETBOX_SESSION_MAX_AGE=1209600

# Set to true when FleetBox is served over HTTPS (e.g. behind an nginx/Caddy
# reverse proxy) so the session cookie gets the `Secure` flag. Keep false for
# plain-HTTP local development.
FLEETBOX_SECURE_COOKIES=false

# Trusted reverse-proxy IP(s) for X-Forwarded-* headers (comma-separated, or *).
# Set this to your nginx host's IP for stricter security; default trusts only
# localhost.
FLEETBOX_FORWARDED_ALLOW_IPS=127.0.0.1

# Password policy and brute-force protection
FLEETBOX_MIN_PASSWORD_LENGTH=8
FLEETBOX_RATE_LIMIT_MAX_ATTEMPTS=10
FLEETBOX_RATE_LIMIT_WINDOW_SECONDS=300

# Per-account lockout (independent of the per-IP limit above): lock an account
# after this many consecutive failed logins, for this many minutes.
FLEETBOX_ACCOUNT_LOCKOUT_MAX_ATTEMPTS=10
FLEETBOX_ACCOUNT_LOCKOUT_MINUTES=15

# Validity of a password-reset link (minutes). The "forgot password" flow needs
# SMTP (below) and FLEETBOX_BASE_URL configured to actually send the email.
FLEETBOX_RESET_TOKEN_MINUTES=60

# Require administrators to have 2FA enabled before they can use the admin area.
# FLEETBOX_REQUIRE_ADMIN_2FA=false

# Document/photo uploads: storage directory (relative paths are resolved against
# the project root) and the maximum size per file in bytes (default: 10 MiB).
FLEETBOX_UPLOAD_DIR=./data/uploads
FLEETBOX_MAX_UPLOAD_BYTES=10485760

# Target of the "Documentation" link in the UI footer. Leave empty to hide it.
FLEETBOX_DOCS_URL=https://github.com/skyhell/fleetbox/tree/main/docs

# Public base URL, used to build links in reminder emails. Leave empty to omit.
# FLEETBOX_BASE_URL=https://fleetbox.example.com

# Email reminders (optional). Configure SMTP to enable the `send-reminders`
# command, which emails users a digest of due services and seasonal tyre swaps.
# Reminders are only sent when FLEETBOX_SMTP_HOST is set.
# FLEETBOX_SMTP_HOST=smtp.example.com
# FLEETBOX_SMTP_PORT=587
# FLEETBOX_SMTP_USER=fleetbox@example.com
# FLEETBOX_SMTP_PASSWORD=your-smtp-password
# FLEETBOX_SMTP_FROM=fleetbox@example.com
# FLEETBOX_SMTP_STARTTLS=true
# FLEETBOX_SMTP_SSL=false

# Seasonal tyre-change reminder months (1-12). Defaults: winter in October,
# summer in April.
# FLEETBOX_WINTER_TIRE_MONTH=10
# FLEETBOX_SUMMER_TIRE_MONTH=4
