# --- FleetBox configuration -------------------------------------------------
# Copy this file to ".env" and adjust the values. See docs/configuration.md.

# REQUIRED: secret used to sign session cookies. Generate a random one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FLEETBOX_SECRET_KEY=change-me-please-generate-a-random-value

# Database URL (SQLAlchemy syntax).
# SQLite (default):
FLEETBOX_DATABASE_URL=sqlite:///./data/fleetbox.db
# PostgreSQL example:
# FLEETBOX_DATABASE_URL=postgresql+psycopg://fleetbox:secret@localhost:5432/fleetbox

# Network
FLEETBOX_HOST=0.0.0.0
FLEETBOX_PORT=8000

# Default UI language: "de" or "en"
FLEETBOX_DEFAULT_LOCALE=de

# Allow self-service registration of new users (true/false).
# When false, only an admin can create users.
FLEETBOX_ALLOW_REGISTRATION=true

# Session lifetime in seconds (default: 14 days)
FLEETBOX_SESSION_MAX_AGE=1209600

# Set to true when FleetBox is served over HTTPS (e.g. behind an nginx/Caddy
# reverse proxy) so the session cookie gets the `Secure` flag. Keep false for
# plain-HTTP local development.
FLEETBOX_SECURE_COOKIES=false

# Trusted reverse-proxy IP(s) for X-Forwarded-* headers (comma-separated, or *).
# Set this to your nginx host's IP for stricter security; default trusts only
# localhost.
FLEETBOX_FORWARDED_ALLOW_IPS=127.0.0.1

# Password policy and brute-force protection
FLEETBOX_MIN_PASSWORD_LENGTH=8
FLEETBOX_RATE_LIMIT_MAX_ATTEMPTS=10
FLEETBOX_RATE_LIMIT_WINDOW_SECONDS=300
